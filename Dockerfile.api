FROM golang:1.26.2-alpine AS build
ARG APP_VERSION=dev

WORKDIR /src

RUN apk add --no-cache ca-certificates

COPY go.mod go.sum ./
RUN go mod download
RUN mkdir -p /out && go install github.com/pressly/goose/v3/cmd/goose@v3.27.1 && cp /go/bin/goose /out/goose

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w -X github.com/sunriseex/capitalflow/internal/version.Release=${APP_VERSION}" -o /out/capitalflow-server ./cmd/server
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w -X github.com/sunriseex/capitalflow/internal/version.Release=${APP_VERSION}" -o /out/capitalflow ./cmd/capitalflow

FROM alpine:3.23
ARG APP_VERSION=dev

ENV APP_VERSION=${APP_VERSION}

LABEL org.opencontainers.image.title="CapitalFlow API" \
    org.opencontainers.image.version="${APP_VERSION}" \
    org.opencontainers.image.source="https://github.com/Sunriseex/CapitalFlow"

RUN apk add --no-cache ca-certificates coreutils postgresql17-client tzdata

WORKDIR /app

COPY --from=build /out/capitalflow-server /usr/local/bin/capitalflow-server
COPY --from=build /out/capitalflow /usr/local/bin/capitalflow
COPY --from=build /out/goose /usr/local/bin/goose
COPY migrations ./migrations
COPY scripts/interest-scheduler.sh /usr/local/bin/capitalflow-interest-scheduler
COPY scripts/interest-schedule.sh /usr/local/bin/capitalflow-interest-schedule
COPY scripts/backup-scheduler.sh /usr/local/bin/capitalflow-backup-scheduler
COPY scripts/backup-schedule.sh /usr/local/bin/capitalflow-backup-schedule
COPY scripts/backup-retention.sh /usr/local/bin/capitalflow-backup-retention
COPY scripts/pre-migration-backup.sh /usr/local/bin/capitalflow-pre-migration-backup
COPY scripts/restore-drill.sh /usr/local/bin/capitalflow-restore-drill
COPY scripts/scheduler-healthcheck.sh /usr/local/bin/capitalflow-scheduler-healthcheck
COPY scripts/disk-guard.sh /usr/local/bin/capitalflow-disk-guard
RUN chmod +x \
    /usr/local/bin/capitalflow-interest-scheduler \
    /usr/local/bin/capitalflow-interest-schedule \
    /usr/local/bin/capitalflow-backup-scheduler \
    /usr/local/bin/capitalflow-backup-schedule \
    /usr/local/bin/capitalflow-backup-retention \
    /usr/local/bin/capitalflow-pre-migration-backup \
    /usr/local/bin/capitalflow-restore-drill \
    /usr/local/bin/capitalflow-scheduler-healthcheck \
    /usr/local/bin/capitalflow-disk-guard

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/capitalflow-server"]
CMD ["--addr", ":8080"]
